; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Worker"
run/main_scene="uid://vmlb1gmyem8b"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://c8ry6xpd6e1ur"

[autoload]

GameSystem="*uid://biwpuy3jxu67f"
EventBus="*uid://clvgxe6d6kfyn"
InputHelper="*uid://cholww48njaeh"

[debug]

gdscript/warnings/unused_signal=0

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"

[dotnet]

project/assembly_name="Worker"

[editor_plugins]

enabled=PackedStringArray("res://addons/FolderLabels/plugin.cfg", "res://addons/input_helper/plugin.cfg")

[file_customization]

folder_colors={
"res://Resource/": "gray",
"res://addons/": "purple",
"res://asset/": "green",
"res://scene/": "blue",
"res://script/": "yellow"
}

